# Copy this file to .env.local for local development.
# Never commit .env.local or real provider secrets.

# AI review provider.
# Use "off" for a local-only/public demo with heuristic fallback.
LSD_AI_PROVIDER=off

# Enable Groq-backed review locally or in a protected self-hosted deployment.
# GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai/v1
LSD_AI_MODEL=openai/gpt-oss-20b
LSD_AI_TIMEOUT_MS=12000

# Magic-link delivery for the server draft claim flow.
# "demo" shows a local activation link in the app.
LSD_MAIL_PROVIDER=demo

# Use "http" only when you have a server-side mail relay endpoint.
# LSD_MAIL_PROVIDER=http
# LSD_MAIL_HTTP_ENDPOINT=https://example.com/mail-hook
# LSD_MAIL_HTTP_BEARER_TOKEN=
# LSD_MAIL_FROM=LS Stringsmith <noreply@example.com>
# LSD_MAIL_PROVIDER_LABEL=Mail relay
